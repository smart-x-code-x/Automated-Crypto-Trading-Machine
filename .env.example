# ═══════════════════════════════════════════════
#  SoDEX Trading Bot — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env with real credentials!

# Your EVM wallet address (used as API key)
SODEX_API_KEY=

# Your EVM private key for signing (keep secret!)
SODEX_PRIVATE_KEY=

# Your SoDEX account ID
SODEX_ACCOUNT_ID=0

# Environment: "mainnet" or "testnet"
SODEX_ENV=mainnet

# Trading mode: "PAPER" (simulation) or "LIVE" (real trades)
TRADING_MODE=PAPER
